// oxidhome.wit
//
// Plugin interface for OxidHome. Source of truth for the host/plugin
// contract; everything else generates code from this file.
//
// The contract is split into focused interfaces. Plugins compose what they
// need by importing the appropriate world.
//
// Four plugin worlds are defined:
//   - plugin              — standard device integrations and automations
//   - streaming-plugin    — adds host-media + WASI sockets/HTTP for long-lived I/O
//   - ai-plugin           — adds inference for ML-driven plugins
//   - streaming-ai-plugin — combines streaming + inference
//
// ── Capability gating ────────────────────────────────────────────────────
// Importing an interface does NOT grant access to it. A component built for
// the `plugin` world MUST satisfy every world import — the host cannot
// refuse to link an import without making the component fail to instantiate
// outright. Capability enforcement therefore happens at the **call site**:
// every host call goes through a permission gate that consults the manifest
// the user approved at install time, and unauthorized calls return
// `error::permission-denied(...)`. Manifests, gating policy, and the audit
// trail live in oxidhome-core.

package oxidhome:plugin@0.1.0;


// ─────────────────────────────────────────────────────────────────────────
// Shared types
// ─────────────────────────────────────────────────────────────────────────

interface types {
  /// Wall-clock milliseconds since the Unix epoch. Use this for anything
  /// that crosses process or system boundaries (events, persisted records,
  /// correlations with external systems).
  type unix-ms = u64;

  /// Monotonic milliseconds since plugin instance start. Use this for
  /// measuring durations and intervals within a single plugin run; values
  /// are not comparable across restarts or with other clocks.
  type monotonic-ms = u64;

  /// Stable identifier for a device within the host's device registry.
  /// Assigned by the host when the plugin registers a device.
  type device-id = string;

  /// Plugin-instance-local identifier the plugin uses to refer to its own
  /// devices before/after registration.
  type local-id = string;

  /// Stable identifier for a service within the host's service registry
  /// (Phase 7). Assigned by the host when the plugin registers a service.
  /// Distinct id-space from `device-id` (the host mints `svc-N`).
  type service-id = string;

  type subscription-id = u64;

  variant value {
    bool-val(bool),
    int-val(s64),
    float-val(f64),
    string-val(string),
    bytes-val(list<u8>),
    /// Structured data, JSON-encoded. Use sparingly; prefer typed records.
    json-val(string),
  }

  record key-value {
    key: string,
    value: value,
  }

  variant error {
    not-found(string),
    invalid-argument(string),
    permission-denied(string),
    unavailable(string),
    internal(string),
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Capabilities — the reusable units that devices compose from
//
// Capability *spec* (what a device CAN do) is separated from capability
// *state* (what its current state is). Devices register a list of specs;
// state flows through events.
// ─────────────────────────────────────────────────────────────────────────

interface capabilities {
  /// Discrete on/off state.
  record switchable {
    state: bool,
  }

  /// 0.0–1.0 continuous level (brightness, fan speed, blind position).
  record dimmable {
    level: f64,
  }

  /// Color in HSV (each 0.0–1.0) plus optional color temperature in Kelvin.
  record color {
    hue: f64,
    saturation: f64,
    value: f64,
    color-temp-kelvin: option<u32>,
  }

  /// Numeric reading with a unit. Units are SI-ish strings:
  /// "celsius", "percent", "lux", "watt", "ppm", etc.
  record measurement {
    value: f64,
    unit: string,
  }

  /// A button press / scene-controller event. Stateless; only delivered
  /// as events, never queried.
  variant button-event {
    pressed,
    released,
    single-press,
    double-press,
    long-press,
    /// Rotational delta; positive values are clockwise.
    rotated(f64),
  }

  /// Spec hints for a color-capable light: which color models the device
  /// supports and the Kelvin range when color-temp is supported.
  record color-light-spec {
    /// Whether full HSV control is supported.
    supports-hsv: bool,
    /// Whether color-temperature control is supported.
    supports-color-temp: bool,
    /// Kelvin range when supports-color-temp is true. None on either side
    /// means "unspecified".
    color-temp-min-kelvin: option<u32>,
    color-temp-max-kelvin: option<u32>,
  }

  /// Spec hints for a sensor: unit and reasonable display range.
  record sensor-spec {
    /// Unit string ("celsius", "percent", "lux", ...).
    unit: string,
    /// Optional reasonable range for UIs and validation.
    min: option<f64>,
    max: option<f64>,
  }

  /// What a device CAN do. Lists at registration time; describes shape, not
  /// current value. Open-ended via the `extension` arm so plugin authors
  /// can add new capability kinds without waiting for the core spec.
  variant capability-spec {
    switch,
    dimmer,
    color-light(color-light-spec),
    sensor(sensor-spec),
    button,
    /// The device exposes a video stream. Plugins set up the actual stream
    /// via the streaming-plugin world's `setup-pipeline` export.
    video-stream,
    /// The device exposes an audio stream. See video-stream.
    audio-stream,
    /// Capability name; semantics negotiated separately. Consumers that
    /// don't recognize the name simply ignore the capability.
    extension(string),
  }

  /// Current state for a stateful capability. Carried as the optional
  /// `initial-state` snapshot on `device-info` at registration time.
  /// Subsequent updates flow through `events::state-change`, which uses a
  /// looser capability-name + key-value field bag rather than this typed
  /// variant. Stateless capabilities (button, video-stream, audio-stream,
  /// extension) have no entry here.
  variant capability-state {
    switch(switchable),
    dimmer(dimmable),
    color-light(color),
    sensor(measurement),
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Devices — registration, state, commands
// ─────────────────────────────────────────────────────────────────────────

interface devices {
  use types.{device-id, local-id, key-value, error};
  use capabilities.{capability-spec, capability-state};

  record device-info {
    local-id: local-id,
    /// Human-readable name. Users may override this through the host UI.
    name: string,
    /// Manufacturer / model / firmware, when known.
    manufacturer: option<string>,
    model: option<string>,
    firmware: option<string>,
    /// What the device can do. Pure shape data — current values flow
    /// through events.
    capabilities: list<capability-spec>,
    /// Optional snapshot of state at registration time, one entry per
    /// stateful capability the plugin can already report. Empty list means
    /// "state will arrive via events".
    initial-state: list<capability-state>,
    /// Free-form metadata the plugin wants persisted with the device.
    metadata: list<key-value>,
  }

  /// A command sent from the host → device (via the plugin that owns the
  /// device). Capability name + arguments. The plugin matches on
  /// capability + action.
  record command {
    /// Capability name: `"switch"`, `"dimmer"`, `"color-light"`, etc.
    capability: string,
    /// Action verb: `"set"`, `"toggle"`, `"increment"`, etc.
    action: string,
    args: list<key-value>,
  }

  variant command-result {
    ok,
    /// Device returned new state inline alongside the OK.
    ok-with-state(list<key-value>),
    err(error),
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Services — non-device peers (automation scripts, virtual integrations)
//
// Mirror of the device shape: a plugin instance registers services it
// owns; commands and results reuse the `devices` `command` /
// `command-result` types so the SDK can share helpers. The driving
// use-case is the embedded scripting plugin where each user script is a
// service that exposes commands and calls into other scripts' commands.
// ─────────────────────────────────────────────────────────────────────────

interface services {
  use types.{local-id, key-value};

  /// Metadata for one command a service exposes. Argument / return
  /// shapes stay textual in 0.1 (no structured-type-in-WIT); plugin
  /// authors match on `name` from `execute-service-command`.
  record command-spec {
    name: string,
    description: option<string>,
    /// Free-form hints like `"mode: string — one of occupied/vacant"`.
    arg-hints: list<string>,
  }

  record service-info {
    /// Plugin-instance-local id, echoed back so the plugin can map the
    /// host-assigned `service-id` to its own bookkeeping.
    local-id: local-id,
    /// Human-readable name. Also the capability key gated by the
    /// manifest's `[capabilities] declares_services`.
    name: string,
    /// Free-form metadata persisted with the service.
    metadata: list<key-value>,
    /// Commands the service accepts. Empty ⇒ an event-only service with
    /// no callable surface.
    commands: list<command-spec>,
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Events — pub/sub between plugins and the host's event bus
// ─────────────────────────────────────────────────────────────────────────

interface events {
  use types.{device-id, unix-ms, key-value, subscription-id};
  use capabilities.{button-event};

  /// Events the host delivers, or that plugins publish.
  variant event-payload {
    /// A device's state changed (sensor reading, switch flipped, etc.).
    state-changed(state-change),
    /// A momentary event from a button or scene controller.
    button(button-event),
    /// Inference results from a pipeline inference-tap.
    inference(inference-result),
    /// Plugin-defined custom event. Topic + JSON payload.
    custom(custom-event),
  }

  record state-change {
    capability: string,
    /// New values for the changed fields (partial state).
    fields: list<key-value>,
  }

  record custom-event {
    topic: string,
    /// JSON-encoded payload.
    payload: string,
  }

  /// Inference results delivered from a pipeline tap.
  /// Generic enough to carry detection bboxes, classification scores,
  /// embeddings, etc. Plugin-specific schema goes in the JSON payload.
  record inference-result {
    /// The model that produced this result (registry name).
    model: string,
    /// JSON-encoded structured output (detections, classes, embeddings).
    payload: string,
    /// Frame timestamp (unix-ms), if applicable.
    frame-timestamp: option<unix-ms>,
  }

  record event {
    /// Empty when the event isn't tied to a specific device (e.g. plugin
    /// lifecycle).
    device: option<device-id>,
    /// Plugin-supplied wall-clock timestamp. The host records its own
    /// receive time separately for trust-sensitive ordering and retention.
    timestamp: unix-ms,
    payload: event-payload,
  }

  /// A topic filter for subscriptions. Both fields optional = match all.
  record event-filter {
    /// Match this device only.
    device: option<device-id>,
    /// Match this capability only ("switch", "sensor", "inference") or
    /// custom event topic prefix.
    topic: option<string>,
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Storage — small persistent KV scoped to the plugin instance
//
// Imported by every plugin world. Capability gated at the call site:
// instances without a `storage_quota_kb` declared in their manifest see
// `error::permission-denied(...)` on every call. Quota is enforced
// transactionally; over-quota writes return permission-denied.
// ─────────────────────────────────────────────────────────────────────────

interface storage {
  use types.{value, error};

  get: func(key: string) -> result<option<value>, error>;
  set: func(key: string, val: value) -> result<_, error>;
  delete: func(key: string) -> result<_, error>;
  list-keys: func(prefix: string) -> result<list<string>, error>;
}


// ─────────────────────────────────────────────────────────────────────────
// Blob store — larger byte payloads (camera snapshots, recordings, oversized
// config). Filesystem-backed on the host; this WIT is the plugin-facing
// surface.
//
// Capability-gated by the manifest's `blob_quota_mb`: 0 (or absent) means
// blob-store calls return `permission-denied` at the call site. A positive
// quota lets calls through; the host enforces total bytes used per
// instance transactionally with the index.
//
// **Phase 5b v1 ships a buffered API**: `write` takes `list<u8>` and
// `read` returns `list<u8>`. Both ends marshal the bytes through the WIT
// boundary in one shot. Fine for blobs measured in single-digit MB — the
// expected workload (per-frame snapshots, short recordings, oversized
// state). Streaming resource handles (`resource blob-writer` /
// `resource blob-reader` with `write`/`finish`/`abort` and chunked
// `read`) are the planned follow-up for plugins that want to stream
// large recordings without buffering end-to-end. The on-disk format
// doesn't change between v1 and the streaming variant — the writer
// already stages to `.tmp/<ulid>` and atomically renames on `finish`.
// ─────────────────────────────────────────────────────────────────────────

interface blob-store {
  use types.{error};

  /// Opaque host-side identifier for one stored blob. The host returns
  /// this from `write`; plugins can keep it for direct `read`s, or use
  /// the human-readable `name` they chose at write time via
  /// `read-by-name` / `delete`.
  type blob-id = string;

  /// Metadata for one stored blob. The byte payload itself is fetched
  /// via `read` / `read-by-name`; `list` returns these records so a
  /// plugin can enumerate without pulling every blob's bytes through
  /// the WIT boundary.
  record blob-info {
    name: string,
    id: blob-id,
    size-bytes: u64,
    /// Host's wall-clock at write time (`finish`), unix-ms.
    created-ms: u64,
    /// Optional MIME hint from the writer. Informational only — the
    /// host doesn't validate or use it for anything.
    mime: option<string>,
  }

  /// Write a blob in one shot. `name` is the human-readable key the
  /// plugin chose (e.g. `"snapshot-2026-05-08T10-15-00.jpg"`). Writing
  /// to an existing name overwrites it atomically (stage to `.tmp` →
  /// fsync → rename → index commit; readers always see the old blob
  /// or the new one, never a half-written file). Returns the host-
  /// minted id for the new blob.
  ///
  /// Errors: `permission-denied` when the quota would be exceeded
  /// or `blob_quota_mb` is 0 in the manifest; `internal` for
  /// filesystem / index failures.
  write: func(
    name: string,
    data: list<u8>,
    mime: option<string>,
  ) -> result<blob-id, error>;

  /// Read a blob by its host-minted id.
  ///
  /// Errors: `not-found` if the id doesn't exist in this instance's
  /// blob namespace; `internal` for filesystem failures.
  read: func(id: blob-id) -> result<list<u8>, error>;

  /// Read a blob by the user-chosen name.
  ///
  /// Errors: `not-found` if no blob with that name exists for this
  /// instance.
  read-by-name: func(name: string) -> result<list<u8>, error>;

  /// Look up metadata without fetching the byte payload.
  get-info: func(name: string) -> result<blob-info, error>;

  /// Delete a blob by name. Returns `Ok(())` whether the blob existed
  /// or not — the WIT delete contract makes no distinction.
  delete: func(name: string) -> result<_, error>;

  /// List blobs whose name starts with `prefix`. Empty prefix
  /// enumerates every blob in the instance. Named `list-blobs`
  /// because `list` is a WIT keyword.
  list-blobs: func(prefix: string) -> result<list<blob-info>, error>;
}


// ─────────────────────────────────────────────────────────────────────────
// Logging
// ─────────────────────────────────────────────────────────────────────────

interface logging {
  enum level { trace, debug, info, warn, error }
  log: func(level: level, message: string);
}


// ─────────────────────────────────────────────────────────────────────────
// Media — pipeline descriptions for streaming plugins
//
// The principle: WASM plugins describe media pipelines; the host runs them
// natively. This keeps codec work out of WASM (where it would be slow and
// can't reach hardware accelerators) while letting plugins handle the
// fiddly proprietary protocol parts where Rust-in-WASM shines.
// ─────────────────────────────────────────────────────────────────────────

interface media {
  use types.{key-value, error};

  /// A source of media bytes.
  variant media-source {
    /// Standard URL the host can open directly: rtsp://, http://, file://
    url(string),
    /// Plugin produces bytes via a host-managed pipe. Used for proprietary
    /// protocols where the plugin must do auth/decryption/re-framing
    /// before bytes can enter a standard pipeline.
    plugin-pipe(plugin-pipe-config),
  }

  record plugin-pipe-config {
    /// Container/framing the plugin will emit: "rtp", "mpegts",
    /// "raw-h264", "raw-mjpeg", etc.
    format: string,
    /// Codec inside that container.
    codec: string,
    /// Sample rate / clock rate / framerate hints (format-dependent).
    parameters: list<key-value>,
  }

  /// A pipeline step the host should apply after the source.
  variant pipeline-step {
    /// Demux/depacketize using a named handler.
    demux(string),
    /// Decode the video. Host may use hardware acceleration.
    decode-video,
    /// Re-encode video to a target codec (used when consumer needs
    /// different codec).
    encode-video(encode-params),
    /// Transcode audio.
    transcode-audio(audio-params),
    /// Apply per-frame filtering (downscale, crop, overlay).
    filter(filter-config),
    /// Tap the pipeline to feed frames into a host-managed ML model.
    /// Inference results are delivered to the plugin as events.
    inference-tap(inference-tap-config),
  }

  record encode-params {
    /// Target codec: `"h264"`, `"h265"`, `"vp9"`, etc.
    codec: string,
    bitrate-kbps: option<u32>,
    keyframe-interval: option<u32>,
  }

  record audio-params {
    /// Target codec: `"opus"`, `"aac"`, `"pcm"`, etc.
    codec: string,
    sample-rate: option<u32>,
    channels: option<u8>,
  }

  record filter-config {
    /// Filter name: `"scale"`, `"crop"`, `"overlay"`, etc.
    name: string,
    parameters: list<key-value>,
  }

  /// Configuration for an in-pipeline inference tap.
  /// All per-frame work happens natively. The plugin only sees the
  /// (small) structured inference output as events.
  record inference-tap-config {
    /// Model registry name.
    model: string,
    /// Optional version pin. None = latest compatible.
    model-version: option<string>,
    /// Sample rate. None = match source framerate.
    fps: option<f32>,
    /// Where in the pipeline to tap.
    tap-point: tap-point,
    /// Event topic to publish results under.
    event-topic: string,
    /// Optional preprocessing applied by the host before inference.
    preprocessing: list<preprocessing-step>,
  }

  enum tap-point {
    /// After decode — raw decoded frames available. Normal choice for
    /// vision.
    post-decode,
    /// After all filtering steps. Used when filtering changes what the
    /// model sees.
    post-filter,
  }

  variant preprocessing-step {
    /// Resize to (width, height).
    resize(tuple<u32, u32>),
    /// Letterbox to (width, height) — preserves aspect ratio with padding.
    letterbox(tuple<u32, u32>),
    /// Per-channel normalize with (mean, std).
    normalize(tuple<f32, f32>),
    to-rgb,
    to-bgr,
  }

  /// What the host should expose this stream as, downstream.
  variant output-sink {
    /// Path under the host's RTSP server.
    rtsp(string),
    /// The host adds a WebRTC track for on-demand peers.
    webrtc,
    /// Path under the host's HLS server.
    hls(string),
    /// Recording-profile name; the host records to storage under that profile.
    record-to-storage(string),
  }

  enum activation-policy {
    /// Pipeline runs only when a consumer is watching.
    on-demand,
    /// Pipeline runs continuously (recording, motion detection).
    always,
    /// Pipeline runs when motion is signaled (linked motion detector).
    motion-triggered,
  }

  /// Full pipeline description the plugin hands to the host.
  record media-pipeline {
    source: media-source,
    steps: list<pipeline-step>,
    sinks: list<output-sink>,
    activation: activation-policy,
  }

  /// A handle to a running pipeline the host owns.
  resource pipeline-handle {
    stop: func();
    update: func(pipeline: media-pipeline) -> result<_, error>;
  }

  /// A writer for a plugin-pipe source. Plugin writes pre-framed bytes
  /// into this; the host's pipeline consumes them.
  resource pipe-writer {
    /// Write a chunk of pre-framed bytes (matching the format declared in
    /// the plugin-pipe-config). Returns bytes written.
    write: func(data: list<u8>) -> result<u64, error>;
    /// Signal end-of-stream and close.
    close: func();
  }
}


// ─────────────────────────────────────────────────────────────────────────
// Inference — host-managed ML model access for AI plugins
//
// Models are first-class platform resources, not application code. The
// host loads, runs, and accelerates them; plugins request inference and
// orchestrate around the results. Capability gated at the call site by
// the manifest's declared model dependencies.
// ─────────────────────────────────────────────────────────────────────────

interface inference {
  use types.{error};

  enum tensor-dtype { %f32, %f16, %i8, %u8, %i32, %i64 }

  record tensor-spec {
    name: string,
    /// Shape in elements per dim. `-1` denotes a dynamic dimension.
    shape: list<s32>,
    dtype: tensor-dtype,
  }

  record named-tensor {
    name: string,
    shape: list<u32>,
    dtype: tensor-dtype,
    /// Raw bytes; layout is row-major, dtype-defined.
    data: list<u8>,
  }

  record model-info {
    name: string,
    version: string,
    inputs: list<tensor-spec>,
    outputs: list<tensor-spec>,
    /// Hint about where it runs: "cuda", "cpu", "metal", "openvino", "cpu-fallback".
    runtime: string,
  }

  /// A handle to a loaded model. Capability-scoped: plugin can only hold
  /// handles for models its manifest authorizes.
  resource model {
    /// Run inference on a single input set (or batch).
    /// Tensors are matched by name to the model's signature.
    infer: func(inputs: list<named-tensor>) -> result<list<named-tensor>, error>;
    /// Model metadata.
    info: func() -> model-info;
  }

  /// Plugin asks the host to load a model from the registry.
  /// Returns a handle the plugin uses for inference.
  load-model: func(name: string, version: option<string>) -> result<model, error>;
}


// ─────────────────────────────────────────────────────────────────────────
// Host imports — split by concern so plugin worlds compose only what they
// can use. Capability is gated at the call site (see header comment).
// ─────────────────────────────────────────────────────────────────────────

/// Device lifecycle: announce devices the plugin manages, look them up.
interface host-devices {
  use types.{device-id, error};
  use devices.{device-info};

  register-device: func(info: device-info) -> result<device-id, error>;
  update-device:   func(id: device-id, info: device-info) -> result<_, error>;
  remove-device:   func(id: device-id) -> result<_, error>;
  /// Look up a device the plugin previously registered. Returns
  /// `error::not-found(...)` if the id is unknown to this plugin.
  get-device:      func(id: device-id) -> result<device-info, error>;
}

/// Service lifecycle + synchronous cross-plugin dispatch (Phase 7).
/// Owner-scoped read/write mirrors `host-devices`: a plugin can only
/// manage services it registered. `register-service` is gated by the
/// manifest's `[capabilities] declares_services`.
interface host-services {
  use types.{service-id, key-value, error};
  use services.{service-info};
  use devices.{command-result};

  register-service: func(info: service-info) -> result<service-id, error>;
  update-service:   func(id: service-id, info: service-info) -> result<_, error>;
  remove-service:   func(id: service-id) -> result<_, error>;
  /// Look up a service the plugin previously registered. Returns
  /// `error::not-found(...)` if the id is unknown to this plugin.
  get-service:      func(id: service-id) -> result<service-info, error>;

  /// Synchronously call another plugin's (or this plugin's own) service
  /// command. The host routes `target` → owning instance, races its
  /// `execute-service-command` export against a timeout, and returns the
  /// result.
  ///
  /// Errors: `not-found` (no such service); `permission-denied`
  /// (call not allowed); `invalid-argument` (recursion `A→…→A`, or the
  /// command/args were rejected); `unavailable` (owner not running, or
  /// the call timed out).
  ///
  /// NOTE: Phase 7b ships this signature with a stub host impl that
  /// returns `unavailable`; the routing dispatcher lands in 7c.
  call-service: func(
    target: service-id,
    command: string,
    args: list<key-value>,
  ) -> result<command-result, error>;
}

/// Event bus pub/sub. Subscribed events are delivered via the plugin's
/// exported `on-event(...)`.
interface host-events {
  use types.{subscription-id, error};
  use events.{event, event-filter};

  publish-event: func(ev: event) -> result<_, error>;
  subscribe:     func(filter: event-filter) -> result<subscription-id, error>;
  unsubscribe:   func(id: subscription-id) -> result<_, error>;
}

/// Per-instance configuration the user set for this plugin instance.
interface host-config {
  use types.{value, key-value, error};

  /// Look up a single config value.
  get-config:  func(key: string) -> result<option<value>, error>;
  list-config: func() -> result<list<key-value>, error>;
}

/// Media pipeline orchestration. Imported only by the streaming worlds —
/// reachability is what gives the standard `plugin` world its no-raw-I/O
/// guarantee. Capability is still gated by the manifest at the call site.
interface host-media {
  use types.{device-id, error};
  use media.{media-pipeline, pipeline-handle, plugin-pipe-config, pipe-writer};

  /// Hand a pipeline description to the host. Host runs it natively.
  start-pipeline: func(
    device: device-id,
    pipeline: media-pipeline,
  ) -> result<pipeline-handle, error>;

  /// Open a writer for a plugin-pipe source. Used when the plugin produces
  /// re-framed bytes from a proprietary protocol.
  open-pipe: func(
    config: plugin-pipe-config,
  ) -> result<pipe-writer, error>;
}


// ─────────────────────────────────────────────────────────────────────────
// Worlds — what kinds of plugins can exist
// ─────────────────────────────────────────────────────────────────────────

/// Standard plugin world. Most plugins (switches, sensors, hubs, automation
/// rules) use this. No raw I/O — communication is via the event bus and
/// the split host-* imports.
world plugin {
  import host-devices;
  import host-events;
  import host-config;
  import host-services;
  import storage;
  import blob-store;
  import logging;

  use types.{device-id, service-id, key-value};
  use devices.{command, command-result};
  use events.{event};

  // Lifecycle
  export init: func() -> result<_, string>;
  export shutdown: func();

  // Event delivery from the host's bus to the plugin
  export on-event: func(ev: event);

  // Commands targeting devices the plugin owns
  export execute-command: func(
    device: device-id,
    cmd: command,
  ) -> command-result;

  // Commands targeting services the plugin owns (Phase 7). Invoked by
  // the host dispatcher when another plugin (or this one) calls
  // `host-services::call-service` against one of this plugin's services.
  // Plugins that expose no services return `command-result::err(...)`.
  export execute-service-command: func(
    service: service-id,
    command: string,
    args: list<key-value>,
  ) -> command-result;

  // Optional periodic tick for plugins that poll. Host calls based on the
  // plugin manifest's requested interval. Plugins that don't need it can
  // return immediately.
  export tick: func();
}

/// Exports unique to the streaming world, packaged as an interface so the
/// world can `export streaming` without re-`use`-ing types that the
/// `include plugin` already pulled in (which would shadow).
interface streaming {
  use types.{device-id};
  use media.{media-pipeline};

  /// Plugin sets up its media pipeline(s) for a given device. Called by
  /// the host after device registration when streaming is needed.
  setup-pipeline: func(device: device-id) -> result<media-pipeline, string>;
}

/// Streaming plugin world — extends the standard world with WASI
/// sockets/HTTP and host-media for cameras, voice assistants, network
/// bridges. Capability is still gated by the manifest; importing these
/// interfaces doesn't grant them.
world streaming-plugin {
  include plugin;
  import host-media;
  import wasi:sockets/tcp@0.2.0;
  import wasi:sockets/udp@0.2.0;
  import wasi:http/outgoing-handler@0.2.0;
  import wasi:clocks/monotonic-clock@0.2.0;
  export streaming;
}

/// AI plugin world — adds inference without streaming, for plugins that
/// run ML on sensor data, anomaly detection, etc.
world ai-plugin {
  include plugin;
  import inference;
}

/// Streaming + AI plugin world — combines streaming I/O with ML model
/// access (e.g., a camera plugin that orchestrates person detection).
world streaming-ai-plugin {
  include streaming-plugin;
  import inference;
}
